generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GuildConfig {
  id      String @id @default(cuid())
  guildId String @unique

  // AI Configuration
  aiEnabled         Boolean  @default(true)
  aiBaseUrl         String   @default("")
  aiModel           String   @default("")
  aiApiKey          String   @default("")
  aiPersonality     String   @default("You are a helpful and friendly Discord bot assistant.")
  aiResponseChance  Int      @default(100)
  aiCooldown        Int      @default(3000)
  aiAllowedChannels String[] @default([])
  aiMaxTokens       Int      @default(1000)
  aiContextMessages Int      @default(10)
  aiReplyOnlyMode   Boolean  @default(false)

  // Moderation Configuration
  moderationEnabled           Boolean  @default(true)
  moderationToxicityThreshold Float    @default(0.7)
  moderationAutoWarn          Boolean  @default(true)
  moderationAutoMute          Boolean  @default(false)
  moderationAutoKick          Boolean  @default(false)
  moderationAutoBan           Boolean  @default(false)
  moderationLogChannelId      String?
  moderationBannedWords       String[] @default([])
  moderationWarnPunishments   Json     @default("[]")

  // Verification Configuration
  verificationEnabled                Boolean @default(false)
  verificationRoleId                 String?
  verificationChannelId              String?
  verificationMethod                 String  @default("button")
  verificationMessage                String  @default("Welcome! Click the button below to verify and gain access to the server.")
  verificationEmoji                  String  @default("✅")
  verificationButtonText             String  @default("Verify")
  verificationAlreadyVerifiedMessage String  @default("✅ You are already verified!")

  // Welcome Configuration
  welcomeEnabled   Boolean @default(false)
  welcomeChannelId String?
  welcomeMessage   String  @default("Welcome {user} to {server}!")
  welcomeUseEmbed  Boolean @default(true)

  // Auto-Role Configuration
  autoRoleEnabled Boolean  @default(false)
  autoRoleIds     String[] @default([])

  // Goodbye Configuration
  goodbyeEnabled   Boolean @default(false)
  goodbyeChannelId String?
  goodbyeMessage   String  @default("Goodbye {user}, we'll miss you!")
  goodbyeUseEmbed  Boolean @default(true)

  // Whitelist Configuration
  whitelistEnabled Boolean  @default(false)
  whitelistUserIds String[] @default([])
  whitelistRoleIds String[] @default([])

  // Command Configuration
  disabledCommands String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moderationLogs ModerationLog[]
  userWarnings   UserWarning[]

  @@index([guildId])
}

model ModerationLog {
  id          String   @id @default(cuid())
  guildId     String
  botId       String?
  userId      String
  moderatorId String
  action      String
  reason      String   @default("No reason provided")
  duration    Int?
  timestamp   DateTime @default(now())

  guild GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId])
  @@index([botId])
  @@index([userId])
  @@index([timestamp])
}

model UserWarning {
  id       String    @id @default(cuid())
  guildId  String
  botId    String?
  userId   String
  warnings Warning[]

  guild GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([botId])
  @@index([userId])
}

model Warning {
  id            String   @id @default(cuid())
  moderatorId   String
  reason        String
  timestamp     DateTime @default(now())
  userWarningId String

  userWarning UserWarning @relation(fields: [userWarningId], references: [id], onDelete: Cascade)

  @@index([userWarningId])
}

model Knowledge {
  id          String   @id @default(cuid())
  guildId     String
  botId       String?
  key         String
  value       String   @db.Text
  category    String   @default("general")
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([guildId, botId, key])
  @@index([guildId])
  @@index([botId])
  @@index([category])
}

model ConversationHistory {
  id        String   @id @default(cuid())
  guildId   String
  botId     String?
  channelId String
  userId    String
  username  String
  role      String
  content   String   @db.Text
  timestamp DateTime @default(now())

  @@index([guildId, channelId, timestamp])
  @@index([channelId])
  @@index([botId, channelId, timestamp])
}

model UserIgnoreList {
  id        String   @id @default(cuid())
  guildId   String
  botId     String?
  userId    String
  ignored   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, botId, userId])
  @@index([guildId])
  @@index([botId])
  @@index([userId])
}

model Bot {
  id                String   @id @default(cuid())
  name              String
  discordAppId      String   @unique
  discordBotUserId  String?  @unique
  encryptedToken    String   @db.Text
  encryptedApiKey   String?  @db.Text
  aiBaseUrl         String   @default("")
  aiModel           String   @default("")
  aiPersonality     String   @default("You are a helpful and friendly Discord bot assistant.")
  aiMaxTokens       Int      @default(1000)
  aiContextMessages Int      @default(10)
  status            String   @default("DISABLED")
  isMigrated        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  guildSettings GuildBotSettings[]

  @@index([status])
}

model GuildBotSettings {
  id      String  @id @default(cuid())
  guildId String
  botId   String
  enabled Boolean @default(false)

  // Per-guild overrides (null = inherit from Bot)
  personalityOverride String?  @db.Text
  responseChance      Int?
  cooldownMs          Int?
  replyOnlyMode       Boolean?
  allowedChannels     String[] @default([])

  // Inter-bot conversation settings
  botToBotEnabled        Boolean @default(false)
  maxChainDepth          Int     @default(3)
  channelCooldownMs      Int     @default(5000)
  circuitBreakerCount    Int     @default(10)
  circuitBreakerWindowMs Int     @default(60000)
  circuitBreakerPauseMs  Int     @default(300000)
  mentionBypassMatrix    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([guildId, botId])
  @@index([guildId])
  @@index([botId])
}

model BotPairChance {
  id           String   @id @default(cuid())
  guildId      String
  speakerBotId String
  targetBotId  String
  chance       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([guildId, speakerBotId, targetBotId])
  @@index([guildId])
  @@index([speakerBotId])
}

model ReactionRoleMessage {
  id          String   @id @default(cuid())
  botId       String
  guildId     String
  channelId   String
  messageId   String
  title       String   @default("")
  description String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bindings ReactionRoleBinding[]

  @@unique([botId, messageId])
  @@index([botId, guildId])
  @@index([guildId])
}

model ReactionRoleBinding {
  id        String   @id @default(cuid())
  messageId String
  emoji     String
  roleId    String
  createdAt DateTime @default(now())

  message ReactionRoleMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, emoji])
  @@index([messageId])
}
