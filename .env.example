# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
CLIENT_SECRET=your_discord_client_secret_here
# Bot owner's Discord user ID (bypasses all whitelist restrictions)
BOT_OWNER_ID=your_discord_user_id_here

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Default AI Configuration (can be overridden per server)
DEFAULT_AI_BASE_URL=https://api.example.com/v1
DEFAULT_AI_MODEL=gpt-4
DEFAULT_AI_API_KEY=your_ai_api_key_here

# Bot Configuration
NODE_ENV=development

# Web Server Configuration
WEB_PORT=3000
SESSION_SECRET=change-this-to-a-random-secret-key-in-production
CALLBACK_URL=http://localhost:3000/api/auth/callback
FRONTEND_URL=http://localhost:5173
